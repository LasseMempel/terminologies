{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/80e298a3-a61b-4f94-828b-b17074238cdd.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/80e298a3-a61b-4f94-828b-b17074238cdd","type":"Concept","prefLabel":{"de":"Verblendeter Saum","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":{"de":["Falscher Saum"],"en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"hiddenLabel":null,"definition":{"de":"Wenn der Stoff nicht ausreicht, um an einem Kleidungsstück einen Saum zu nähen, und bei Paillettenstoffen wird ein falscher Saum aus farblich abgestimmtem Futterstoff oder Garniturstoff (Band, Schrägstreifen, Formstreifen) angesetzt. Dazu wird ein ca. 6 cm breiten Stoff- oder Futterstreifen zugeschnitten und rechts auf rechts entlang der markierten Saumlinie festgesteppt, die Nahtzugaben auseinandergebügelt. Dann wird der falsche Saum nach innen umgeheftet, die Kante gebügelt, die Saumzugabe eingeschlagen und hohl angenäht oder festgesteppt.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["80e298a3-a61b-4f94-828b-b17074238cdd"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/c91a469f-b2c8-42d6-82b6-ff4288123ef5","prefLabel":{"de":"gesäumt <Textile Technik>","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus"}],"topConceptOf":[],"deprecated":null,"isRepla