{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/0c66924b-045e-4611-a08e-bac6b581ab2e.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/0c66924b-045e-4611-a08e-bac6b581ab2e","type":"Concept","prefLabel":{"de":"Tiefdruck","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Der auf den Hochdruck folgende, historisch zweite Haupttyp der Grafiktechnologien. Versammelt werden in diesem Typ alle Drucktechniken, bei denen die im Druckrelief tiefligenden Teile die Farbe an das Papier abgeben, während die hochliegenden, von Farbe blankgewischten Teile keine Druckspur hinterlassen. Aufkommend mit dem -> Kupferstich um 1420 und der -> Radierung um 1510 bildet die T.-Technologie eine breite Basis für Fortentwicklungen, die bis ins industrielle Zeitalter reichen.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["0c66924b-045e-4611-a08e-bac6b581ab2e"],"example":null,"narrower":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/52b067c8-e0ec-42b6-b5c6-6c50322c95ca","prefLabel":{"de":"Radierung","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/5c6c86c7-5663-4525-9593-0517ecdae263","prefLabel":{"de":"Kupferstich","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/81b880f8-f190-4ed4-a264-d99f8cf3dd13","prefLabel":{"de":"Aquatinta","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}}],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/f23ad0e5-36b6-41d7-b9d0-26ece1c5