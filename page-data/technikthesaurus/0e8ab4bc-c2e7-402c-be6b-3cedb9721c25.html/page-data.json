{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/0e8ab4bc-c2e7-402c-be6b-3cedb9721c25.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/0e8ab4bc-c2e7-402c-be6b-3cedb9721c25","type":"Concept","prefLabel":{"de":"eingehalten <Textile Technik>","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Einhalten kann für die Formgebung eines Modells nötig sein, zum Beispiel bei Schulternähten. Hier ist das Rückenteil weiter als das Vorderteil. Beim Zusammennähen der Kanten wird die Mehrweite des Rückenteils auf die Weite des Vorderteils zusammengeschoben. Dabei soll nur soviel Weite angeschoben werden, dass keine Fältchen entstehen. Zum Einhalten wird häufig neben der markierten Nahtlinie einen Hilfsfaden eingezogen, den man auf die gewünschte Weite anzieht. Die Naht wird von der einzuhaltenden Kante aus gesteppt.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["0e8ab4bc-c2e7-402c-be6b-3cedb9721c25"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/6b0d9794-6c60-4e6d-adf6-5c3fff6fd23e","prefLabel":{"de":"Verarbeitungs- und Verzierungstechnik <Textile Technik>","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://www.lassemempel.github.io/term