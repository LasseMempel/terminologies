{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/4b628ee3-5bef-4e42-90e9-eb176177a61d.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/4b628ee3-5bef-4e42-90e9-eb176177a61d","type":"Concept","prefLabel":{"de":"halber Abnäher","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":{"de":["einfacher Abnäher"],"en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"hiddenLabel":null,"definition":{"de":"Der Stoff wird so gefaltet, dass die Abnäherlinien aufeinandertreffen, rechte Stoffseite innen. Die Abnäherlinien werden von der Spitze beginnend aufeinandergesteckt oder geheftet und die Abnäher von der Breitseite aus gesteppt. Die Nahtenden werden durch Vor- und Zurücknähen gesichert oder die Fadenenden verknotet. Der Abnäher wird zunächst flachgebügelt, dann nach einer Seite gebügelt, immer von der Breitseite zur Spitze. In der Regel werden Brustabnäher nach unten, Taillenabnäher (senkrechte Abnäher) zur Mitte hin gebügelt.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["4b628ee3-5bef-4e42-90e9-eb176177a61d"],"example":null,"narrower":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/a2b80e08-00bc-496e-ad66-82d21156f492","prefLabel":{"de":"Abspringender Abnäher","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/aada8ea7-1bc0-4e5c-bf1c-ec2496b16fb1","prefLabel":{"de":"Brustabnäher","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}}],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/04c46f2c-e80c-4c64-a081-58267334341e","prefLabel":{"de":"abgenäht <Textile Technik>","e