{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/f268d3ab-bd7f-4b77-9fb5-90c7154b2827.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/f268d3ab-bd7f-4b77-9fb5-90c7154b2827","type":"Concept","prefLabel":{"de":"aufgeschnittener Abnäher","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Bei sehr dicken Stoffen wird der Abnäher flach, wenn er aufgeschnitten wird. Dazu wird zunächst ein einfacher Abnäher genäht. Bei breiten Abnähern die Abnähertiefe ca. 1 bis 1,5 cm neben der Stepplinie abgeschnitten. Die Kanten werden auseinandergebügelt und der Abnäher bis zur Spitze auf den Kopf gebügelt. Bei schmalen Abnähern wird die Abnähertiefe bis ca. 5 cm vor die Spitze in der Mitte aufgeschnitten, dann gebügelt.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["f268d3ab-bd7f-4b77-9fb5-90c7154b2827"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/04c46f2c-e80c-4c64-a081-58267334341e","prefLabel":{"de":"abgenäht <Textile Technik>","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://www.lassemempel.github.io/terminologies/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}