{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/2015a393-8bb1-4a0b-8a78-4eee120eed3a.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/2015a393-8bb1-4a0b-8a78-4eee120eed3a","type":"Concept","prefLabel":{"de":"Abgekurbelter Saum","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Bei Sonnenplisseeröcken, an Rüschen und Volants wird die Saumkante mit dicht eingestelltem Zickzackstich abgesteppt = abgekurbelt. Dazu wird die Saumzugabe nach innen umgebügelt. Die Bruchkante mit dicht eingestelltem Zickzackstich abgesteppt und dann die Zugabe dicht neben den Stichen abgeschnitten. Soll die Saumkante nicht gerade, sondern in weichen Wellen fallen, wird beim Abkurbeln die Kante gedehnt und ein Perlonfaden (z. B. eine Angelschnur) mitgefaßt.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["2015a393-8bb1-4a0b-8a78-4eee120eed3a"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/c91a469f-b2c8-42d6-82b6-ff4288123ef5","prefLabel":{"de":"gesäumt <Textile Technik>","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://www.lassemempel.github.io/terminologies/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}