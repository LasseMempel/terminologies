{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/47cbe897-aa89-47cb-94f5-06463c8821af.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/47cbe897-aa89-47cb-94f5-06463c8821af","type":"Concept","prefLabel":{"de":"Augenknopfloch","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Bei waagrecht eingearbeiteten Knopflöchern, wie an Blusen, wird ein Augenknopfloch genäht. Es unterscheidet sich vom Wäscheknopfloch nur dadurch, dass am vorderen Knopflochende eine Rundung genäht wird. Dazu wird am vorderen Knopflochende strahlenförmig eingestochen, so dass sich eine Rundung bildet. Die Knötchen werden an der Rundung etwas nach oben gezogen. Am anderen Knopflochende wird ein Riegel genäht.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["47cbe897-aa89-47cb-94f5-06463c8821af"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/52ca6b91-3a35-4c7f-80fd-68fc0e3ef084","prefLabel":{"de":"geknöpft <Textile Technik>","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://www.lassemempel.github.io/terminologies/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}