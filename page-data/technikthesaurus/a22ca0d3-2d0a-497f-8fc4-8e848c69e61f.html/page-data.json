{"componentChunkName":"component---src-components-concept-jsx","path":"/technikthesaurus/a22ca0d3-2d0a-497f-8fc4-8e848c69e61f.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/a22ca0d3-2d0a-497f-8fc4-8e848c69e61f","type":"Concept","prefLabel":{"de":"Wachsfadentechnik","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Fäden aus gereinigtem Bienenwachs werden um einen Tonkern gelegt und ihrerseits mit Ton ummantelt. An den Gießling wird unten ein Tontiegel mit Altmetall modelliert und dieser ins Feuer gestellt. Das Wachs verbrennt nun und es bildet sich ein Hohlraum. Sobald das Metall flüssig ist, wird Tonform samt Tiegel umgedreht, so dass die Schmelze den Hohlraum ausfüllt. Nach dem Erkalten des Metalls wird der Tonmantel zerschlagen.","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["a22ca0d3-2d0a-497f-8fc4-8e848c69e61f"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus/8fc7d763-61f2-4fbf-8af8-d2dea1d46a15","prefLabel":{"de":"Wachsausschmelzverfahren","en":null,"fr":null,"dk":null,"es":null,"gr":null,"it":null,"nl":null,"pl":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/terminologies/technikthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://www.lassemempel.github.io/terminologies/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}