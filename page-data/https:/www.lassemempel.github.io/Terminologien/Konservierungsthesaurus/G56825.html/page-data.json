{"componentChunkName":"component---src-components-concept-jsx","path":"/https://www.lassemempel.github.io/Terminologien/Konservierungsthesaurus/G56825.html","result":{"pageContext":{"node":{"id":"https://www.lassemempel.github.io/Terminologien/Konservierungsthesaurus/G56825","type":"Concept","prefLabel":{"de":"gefräst","en":null,"fr":null},"altLabel":{"de":["Fräsen","Fräsung"],"en":null,"fr":null},"hiddenLabel":null,"definition":{"de":"spangebendes Fertigungsverfahren, bei dem Material von einem Werkstück durch die rotierende Bewegung eines mehrschneidigen Werkzeugs (Fräser) bei gleichzeitig verlaufender Vorschubbewegung abgetragen wird. Dabei kann der Fräser und/oder das Werkstück in verschiedenen Achsen bewegt werden, um komplexe Geometrien und Oberflächen herzustellen. Dieses Verfahren wird häufig zur Formgebung von Metallen, Kunststoffen und anderen Werkstoffen eingesetzt, wobei je nach Material und angestrebter Form unterschiedlich geformte Fräser eingesetzt werden.","en":null,"fr":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["G56825"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://www.lassemempel.github.io/Terminologien/Konservierungsthesaurus/AGG387","prefLabel":{"de":"formgebende Technik","en":null,"fr":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://www.lassemempel.github.io/Terminologien/Konservierungsthesaurus","title":null}],"inSchemeAll":[{"id":"https://www.lassemempel.github.io/Terminologien/Konservierungsthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://www.lassemempel.github.io/terminologies/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}